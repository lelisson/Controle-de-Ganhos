# Copie para .env na raiz do projeto (opcional): copy env.example .env
# O Docker Compose lê variáveis do ambiente / arquivo .env automaticamente.

# --- PWA (build Vercel / Expo) ---
# 1 = exige tela de assinatura + API /api/me. Omita ou use 0 para app aberto (padrão recomendado agora).
EXPO_PUBLIC_REQUIRE_SUBSCRIPTION=0
# Token que sempre libera acesso (útil para testes). Em produção use um valor longo e secreto.
TEST_ACCESS_TOKEN=motorista-teste
# Lista separada por vírgula de tokens válidos (ex.: gerados após pagamento confirmado).
VALID_ACCESS_TOKENS=
# Origens CORS permitidas para a API. Use * em dev; em produção restrinja ao seu domínio.
CORS_ORIGIN=*

# --- Build do PWA (container `web`) ---
# URL da API no navegador. Vazio = mesmo site (Nginx encaminha /api para o backend). Recomendado em produção.
EXPO_PUBLIC_API_URL=
# 1 = pula tela de assinatura (só para teste local de UI, não use em produção).
EXPO_PUBLIC_SKIP_PAYWALL=0
# 1 = mostra dica de token de teste na tela de assinatura.
EXPO_PUBLIC_SHOW_TEST_HINT=1
# Link da sua página de pagamento (Mercado Pago, Stripe, Hotmart, etc.).
EXPO_PUBLIC_CHECKOUT_URL=https://exemplo.com/assinatura

# --- Desenvolvimento no PC (sem Docker no front) ---
# 1) Suba só a API: docker compose up api
# 2) No PowerShell, na pasta medidor-ganho:
#    $env:EXPO_PUBLIC_API_URL="http://localhost:3000"; $env:EXPO_PUBLIC_SHOW_TEST_HINT="1"; npm run web
# 3) Abra o endereço que o Expo mostrar; ative com o token igual a TEST_ACCESS_TOKEN.
